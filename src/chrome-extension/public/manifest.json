{
  "manifest_version": 3,
  "name": "Qlik MCP Bridge",
  "version": "1.0.0",
  "description": "Connect Claude to Qlik Sense via MCP",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://*.qlikcloud.com/*",
    "https://*.qlik.com/*",
    "https://*.adtima.vn/*",
    "http://localhost:*/*",
    "https://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.qlikcloud.com/*",
        "https://*.qlik.com/*",
        "https://*.adtima.vn/*",
        "http://localhost:*/sense/*",
        "https://localhost:*/sense/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
